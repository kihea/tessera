{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "A.woke",
  "version": "0.1.0",
  "identifier": "app.tessera.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "A.woke — learn from the sources themselves",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
